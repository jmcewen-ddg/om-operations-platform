# Example env file for the OM Operations Platform.
#
# Copy to .env.local to override locally (gitignored), or edit
# .env.development / .env.production for committed defaults.
#
# Only VITE_* prefixed variables are exposed to the client bundle.

# Dev/UAT role switcher. true = render the RoleSwitcher UI.
# Always false in production.
VITE_ROLE_SWITCHER=false
